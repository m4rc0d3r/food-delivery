{
  "name": "backend",
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-orm": "^0.45.1",
    "fp-ts": "^2.16.11",
    "hono": "^4.12.9",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "pg": "^8.20.0",
    "uid-safe": "^2.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/uid-safe": "^2.1.5",
    "@workspace/core": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "type-fest": "^5.5.0",
    "wrangler": "^4.4.0"
  },
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "scripts": {
    "build": "concurrently --kill-others-on-fail -p \"[{name}]\" -n \"TSC,SWC\" -c \"blue.bold,yellow.bold\" \"pnpm build:ts\" \"pnpm build:swc\"",
    "build:swc": "swc src -d dist --strip-leading-paths",
    "build:ts": "tsc -p tsconfig.app.json",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "deploy": "wrangler deploy --minify",
    "dev": "wrangler dev",
    "type-check": "tsc --noEmit"
  },
  "type": "module"
}
