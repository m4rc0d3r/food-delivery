NODE_ENV=dev

THIS_HOST=localhost

AUTH_ACCESS_TOKEN_SECRET=AUTH_ACCESS_TOKEN_SECRET
AUTH_ACCESS_TOKEN_LIFETIME=30s
AUTH_TOKEN_COOKIE_NAME=AUTH_TOKEN_COOKIE_NAME

BCRYPT_ROUNDS_FOR_PASSWORD_HASH=10

CLIENT_APP_PROTOCOL=http
CLIENT_APP_ADDRESS=${THIS_HOST}
CLIENT_APP_PORT=5173

COOKIE_SECRET=COOKIE_SECRET
COOKIE_DOMAIN=${THIS_HOST}
COOKIE_SECURE=auto

CORS_ORIGIN=${CLIENT_APP_PROTOCOL}://${CLIENT_APP_ADDRESS}:${CLIENT_APP_PORT}
CORS_CREDENTIALS=true

DRIZZLE_DATABASE_URL=postgresql://postgres:postgres@${THIS_HOST}:5432/food_delivery
DRIZZLE_CASING=snake_case

SERVER_PROTOCOL=http
SERVER_ADDRESS=${THIS_HOST}
SERVER_PORT=3000
